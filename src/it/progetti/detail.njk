---
layout: layouts/base.njk
pagination:
  data: collections.projects
  size: 1
  alias: project
permalink: "/progetti/{{ project.data.slug }}/"
pageKey: projects
eleventyComputed:
  title: "{{ project.data.title_it }}"
  translationKey: "project:{{ project.data.slug }}"
---
{% set p = project.data %}
<article class="project-detail">
  <div class="project-body">
    <header class="project-head" data-reveal>
      <h1 class="eyebrow">{{ p | field('title', lang) }}</h1>
      <p class="project-meta"><span>{{ p.location }}</span><span>{{ p.year }}</span></p>
    </header>

    <div class="project-text" data-reveal>
      <p>{{ p | field('description', lang) }}</p>
    </div>

    <div class="project-gallery">
      {% for g in p.gallery %}
        {% if g['text_' + lang] %}
          <div class="project-text" data-reveal>
            <p>{{ g['text_' + lang] }}</p>
          </div>
        {% else %}
          <figure data-reveal{% if g.span == 'full' %} class="is-full"{% endif %}>
            <button class="g-trigger" type="button" aria-label="{{ ui[lang].enlarge }} {{ loop.index }}" data-caption="{{ g['caption_' + lang] }}">
              {% image g.image, g['caption_' + lang], ('100vw' if g.span == 'full' else '(max-width:600px) 100vw, 50vw') %}
            </button>
            {% if g['caption_' + lang] %}<figcaption>{{ g['caption_' + lang] }}</figcaption>{% endif %}
          </figure>
        {% endif %}
      {% endfor %}
    </div>

    {% set base = '/progetti/' %}
    <nav class="project-nav" aria-label="Navigazione progetti">
      {% if pagination.pageNumber > 0 %}
        {% set prev = collections.projects[pagination.pageNumber - 1] %}
        <a class="project-nav__item project-nav__prev" href="{{ base }}{{ prev.data.slug }}/">
          <span class="eyebrow">{{ ui[lang].prev }}</span>
          <span class="project-nav__title">{{ prev.data | field('title', lang) }}</span>
        </a>
      {% else %}<span></span>{% endif %}
      {% if pagination.pageNumber < (collections.projects | length) - 1 %}
        {% set next = collections.projects[pagination.pageNumber + 1] %}
        <a class="project-nav__item project-nav__next" href="{{ base }}{{ next.data.slug }}/">
          <span class="eyebrow">{{ ui[lang].next }}</span>
          <span class="project-nav__title">{{ next.data | field('title', lang) }}</span>
        </a>
      {% endif %}
    </nav>
  </div>
</article>

{% include "partials/lightbox.njk" %}
