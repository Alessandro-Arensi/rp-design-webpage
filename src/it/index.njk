---
layout: layouts/base.njk
permalink: /
pageKey: home
translationKey: home
bodyClass: is-home
---
{% include "partials/intro.njk" %}

<section class="s-hero" data-hero>
  <div class="s-hero__media">
    {% image settings[lang].homeHero, "", "100vw", { eager: true } %}
  </div>
  <div class="s-hero__overlay"></div>
  <div class="s-hero__sign" aria-hidden="true"></div>
  <a class="s-hero__scroll" href="#intro" aria-label="{{ ui[lang].scroll }}"><span class="s-hero__chevrons" aria-hidden="true"></span></a>
</section>

<section id="intro" class="section bleed home-intro">
  <div class="home-intro__head" data-reveal>
    <h1 class="home-headline">{{ settings[lang].tagline }}</h1>
    <p class="lead">{{ home[lang].subtitle }}</p>
  </div>
  {% for block in home[lang].blocks %}
    <div class="home-block row row-y-center" data-reveal>
      <div class="column large-half medium-full home-block__media">
        {% image block.image, block.alt, "(max-width:800px) 100vw, 50vw" %}
      </div>
      <div class="column large-half medium-full">
        <p>{{ block.text }}</p>
      </div>
    </div>
  {% endfor %}
  <p class="home-intro__cta" data-reveal>
    <a class="btn btn--stroke" href="{{ nav[lang].studio.url }}">{{ nav[lang].studio.label }}</a>
  </p>
</section>

{% include "partials/netlify-identity.njk" %}
