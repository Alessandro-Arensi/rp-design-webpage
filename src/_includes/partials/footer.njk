<footer class="s-footer">
  <div class="s-footer__top">
    <span class="s-footer__logo-img" role="img" aria-label="{{ settings[lang].siteName }}"></span>
    <div class="s-footer__cols">
      <nav class="s-footer__col" aria-label="Social">
        {% for s in settings[lang].social %}<a href="{{ s.url }}" rel="noopener" target="_blank">{{ s.label }}</a>{% endfor %}
      </nav>
      <div class="s-footer__col">
        <p><a href="https://maps.app.goo.gl/7rcYGewRCh8eLsQLA" target="_blank" rel="noopener">{{ contact[lang].address.street }}, {{ contact[lang].address.city }}</a></p>
        {% if contact[lang].emails.general %}<a href="mailto:{{ contact[lang].emails.general }}">{{ contact[lang].emails.general }}</a>{% endif %}
        {% if contact[lang].phone %}<a href="tel:{{ contact[lang].phone | replace(' ', '') }}">{{ contact[lang].phone | replace(' ', '&nbsp;') | safe }}</a>{% endif %}
      </div>
    </div>
  </div>
  <div class="s-footer__bottom">
    <span class="s-footer__copy">© {{ settings[lang].siteName }} {{ currentYear }} · P.Iva {{ settings[lang].vat }}</span>
    <nav class="s-footer__legal" aria-label="{{ 'Note legali' if lang == 'it' else 'Legal' }}">
      {# TODO: point these at real pages once they exist #}
      <a href="#">{{ ui[lang].privacy }}</a>
      <a href="#">{{ ui[lang].cookie }}</a>
    </nav>
  </div>
</footer>
