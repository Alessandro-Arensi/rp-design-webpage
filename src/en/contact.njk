---
layout: layouts/base.njk
permalink: /en/contact/
pageKey: contact
translationKey: contact
title: Contact
---
<section class="section bleed page-top">
  <p class="eyebrow" data-reveal>{{ contact[lang].heading }}</p>
  <h1 class="statement" data-reveal>{{ contact[lang].intro }}</h1>

  <div class="contact-emails" data-reveal>
    {% if contact[lang].emails.general %}<div><p class="eyebrow">{{ ui[lang].general }}</p><a href="mailto:{{ contact[lang].emails.general }}">{{ contact[lang].emails.general }}</a></div>{% endif %}
    {% if contact[lang].emails.press %}<div><p class="eyebrow">{{ ui[lang].press }}</p><a href="mailto:{{ contact[lang].emails.press }}">{{ contact[lang].emails.press }}</a></div>{% endif %}
    {% if contact[lang].emails.careers %}<div><p class="eyebrow">{{ ui[lang].careers }}</p><a href="mailto:{{ contact[lang].emails.careers }}">{{ contact[lang].emails.careers }}</a></div>{% endif %}
  </div>

  <div class="contact-showroom" data-reveal>
    {% if contact[lang].showroom.heading %}<p class="eyebrow">{{ contact[lang].showroom.heading }}</p>{% endif %}
    <address>
      {{ contact[lang].address.street }}<br>{{ contact[lang].address.zip }} {{ contact[lang].address.city }}, {{ contact[lang].address.country }}
    </address>
    {% if contact[lang].showroom.text %}<p class="measure">{{ contact[lang].showroom.text }}</p>{% endif %}
  </div>

  {% if contact[lang].formTitle %}<h2 class="lead measure" data-reveal>{{ contact[lang].formTitle }}</h2>{% endif %}
  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/en/contact/thanks/" class="measure" data-reveal>
    <input type="hidden" name="form-name" value="contact">
    <p hidden><label>Do not fill <input type="text" name="bot-field"></label></p>
    <label>{{ ui[lang].name }}<input type="text" name="name" required></label>
    <label>{{ ui[lang].email }}<input type="email" name="email" required></label>
    <label>{{ ui[lang].message }}<textarea name="message" rows="5" required></textarea></label>
    <button class="btn btn--stroke" type="submit">{{ ui[lang].send }}</button>
  </form>
</section>
