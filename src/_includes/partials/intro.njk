{# Home intro curtain. Decorative (aria-hidden); shown only on first visit via
   html.intro-play. JS lifts it; no-JS/reduced-motion never show it. #}
<div class="intro" data-intro aria-hidden="true">
  <p class="intro__wordmark"><span class="line"><span>{{ settings[lang].introWordmark }}</span></span></p>
</div>
