<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>

<title>{% if title %}{{ title }} — {{ settings[lang].siteName }}{% else %}{{ settings[lang].siteName }}{% endif %}</title>
<meta name="description" content="{{ description or settings[lang].tagline }}">

{# Open Graph / Twitter. TODO: replace og:image with a 1200x630 brand image
   (then switch twitter:card to summary_large_image). #}
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ settings[lang].siteName }}">
<meta property="og:title" content="{% if title %}{{ title }} — {{ settings[lang].siteName }}{% else %}{{ settings[lang].siteName }}{% endif %}">
<meta property="og:description" content="{{ description or settings[lang].tagline }}">
<meta property="og:locale" content="{{ 'it_IT' if lang == 'it' else 'en_GB' }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.url }}/android-chrome-512x512.png">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{% if title %}{{ title }} — {{ settings[lang].siteName }}{% else %}{{ settings[lang].siteName }}{% endif %}">
<meta name="twitter:description" content="{{ description or settings[lang].tagline }}">

{# hreflang alternates #}
{%- set alts = collections.all | localeAlternates(translationKey) -%}
{%- for a in alts %}
<link rel="alternate" hreflang="{{ a.lang }}" href="{{ site.url }}{{ a.url }}">
{%- endfor %}
{%- if alts | length %}
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ collections.all | localeHref(translationKey, 'it') }}">
{%- endif %}

{# favicons #}
<link rel="icon" href="/assets/icons/favicon-rp.svg" type="image/svg+xml">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">

{# brand tokens — editable from the CMS via settings #}
<style>
  :root {
    --c-bg: {{ settings[lang].colors.bg }};
    --c-ink: {{ settings[lang].colors.ink }};
    --c-ink-soft: {{ settings[lang].colors.inkSoft }};
    --c-line: {{ settings[lang].colors.line }};
    --c-accent: {{ settings[lang].colors.accent }};
    --c-dark: {{ settings[lang].colors.dark }};
    --ff-display: {{ settings[lang].fonts.display | safe }};
    --ff-body: {{ settings[lang].fonts.body | safe }};
  }
</style>

<link rel="preload" href="/assets/fonts/ABCArizonaFlare-Light.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/dm-sans-400.woff2" as="font" type="font/woff2" crossorigin>

<link rel="stylesheet" href="/assets/css/base.css">
<link rel="stylesheet" href="/assets/css/app.css">
{% if pageKey == 'home' %}
{# Arm the intro curtain before first paint, first visit only (no flash on repeat/reduced-motion). #}
<script>(function(){var d=document.documentElement;try{var r=matchMedia("(prefers-reduced-motion: reduce)").matches;var s=sessionStorage.getItem("piana_intro");if(!r&&!s){d.classList.add("intro-play");}}catch(e){}})();</script>
{% endif %}
