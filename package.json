{
  "name": "piana-design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PIANA — luxury architecture studio website (Eleventy + Sveltia CMS, bilingual IT/EN). See PROJECT_ANALYSIS.md and docs/superpowers/specs.",
  "scripts": {
    "build": "eleventy",
    "dev": "eleventy --serve --port 8000",
    "clean": "rm -rf dist",
    "lint:html": "html-validate \"dist/**/*.html\"",
    "lint:css": "stylelint \"src/assets/css/app.css\"",
    "lint:js": "eslint \"src/assets/js/**/*.js\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "links": "linkinator dist --recurse --skip \"node_modules|reports\""
  },
  "dependencies": {
    "gsap": "^3.12.0",
    "lenis": "^1.1.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.0",
    "clean-css-cli": "^5.6.0",
    "decap-server": "^3.7.0",
    "eslint": "^9.0.0",
    "gh-pages": "^6.0.0",
    "globals": "^17.6.0",
    "html-validate": "^8.7.0",
    "imagemin-cli": "^8.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "lighthouse": "^12.0.0",
    "linkinator": "^6.0.0",
    "pa11y-ci": "^4.1.1",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "svgo": "^3.0.0",
    "terser": "^5.0.0"
  }
}
