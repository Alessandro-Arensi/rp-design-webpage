{# Project gallery lightbox. Hidden via the `hidden` attribute until gallery.js
   opens it (so its buttons are out of the tab order + AT when closed). #}
<div class="lightbox" data-lightbox hidden role="dialog" aria-modal="true" aria-label="{{ ui[lang].gallery }}">
  <button class="lightbox__close" type="button" aria-label="{{ ui[lang].close }}">&times;</button>
  <button class="lightbox__nav lightbox__prev" type="button" aria-label="{{ ui[lang].prev }}">&lsaquo;</button>
  <figure class="lightbox__figure">
    <img class="lightbox__img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="">
    <figcaption class="lightbox__cap" hidden></figcaption>
  </figure>
  <button class="lightbox__nav lightbox__next" type="button" aria-label="{{ ui[lang].next }}">&rsaquo;</button>
</div>
